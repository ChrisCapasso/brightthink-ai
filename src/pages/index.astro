---
import Layout from '../layouts/Layout.astro';
import content from '../content/homepage.json';
---

<Layout>
  <!-- NAV -->
  <nav class="nav">
    <div class="container nav-inner">
      <a href="/" class="nav-logo">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
          <circle cx="12" cy="8" r="3" stroke="#5B8AFF" stroke-width="1.5" fill="none"/>
          <path d="M12 11v6" stroke="#5B8AFF" stroke-width="1.5" stroke-linecap="round"/>
          <path d="M9 20l3-3 3 3" stroke="#5B8AFF" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          <path d="M6 6.5C3.5 8.5 3 12 4.5 15" stroke="rgba(91,138,255,0.3)" stroke-width="1" stroke-linecap="round"/>
          <path d="M18 6.5C20.5 8.5 21 12 19.5 15" stroke="rgba(91,138,255,0.3)" stroke-width="1" stroke-linecap="round"/>
        </svg>
        <span>Brightthink</span>
      </a>
      <div class="nav-links">
        <a href="#services">Services</a>
        <a href="#about">About</a>
        <a href="#contact" class="nav-cta">Get in touch</a>
      </div>
      <button class="nav-toggle" aria-label="Menu">
        <span></span><span></span>
      </button>
    </div>
  </nav>

  <!-- HERO -->
  <section class="hero">
    <div class="hero-mesh"></div>
    <div class="hero-grid"></div>
    <div class="hero-scanlines"></div>
    <div class="container hero-content">
      <span class="pill"><span class="pill-dot"></span> {content.hero_pill}</span>
      <h1>{content.hero_tagline}<br><em>{content.hero_tagline_em}</em></h1>
      <p class="hero-sub">{content.hero_sub}</p>
      <div class="hero-ctas">
        <a href="#contact" class="btn-primary">Let's talk <span aria-hidden="true">→</span></a>
        <a href="#services" class="btn-ghost">See what I build</a>
      </div>
    </div>
  </section>

  <div class="divider"></div>

  <!-- SERVICES -->
  <section id="services" class="section">
    <div class="container">
      <p class="section-label">Services</p>
      <h2 class="section-title">What I build</h2>
      <p class="section-sub">Practical AI that fits how you already work.</p>
      <div class="services-grid">
        <div class="svc-card">
          <div class="svc-icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#5B8AFF" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="12" rx="2"/><path d="M9 20h6"/><path d="M12 16v4"/><circle cx="9" cy="10" r="1" fill="#5B8AFF"/><circle cx="15" cy="10" r="1" fill="#5B8AFF"/></svg>
          </div>
          <h3>Custom AI agents</h3>
          <p>Autonomous agents that handle the tasks your team does manually every single day.</p>
        </div>
        <div class="svc-card">
          <div class="svc-icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#5B8AFF" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 8h16"/><path d="M4 16h16"/><path d="M8 4v4"/><path d="M16 16v4"/><path d="M8 12l4-4 4 4"/><path d="M8 12l4 4 4-4"/></svg>
          </div>
          <h3>Workflow automation</h3>
          <p>Connect your tools. Eliminate the busywork. Let your team focus on what actually matters.</p>
        </div>
        <div class="svc-card">
          <div class="svc-icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#5B8AFF" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M12 2v4"/><path d="M12 18v4"/><path d="M4.93 4.93l2.83 2.83"/><path d="M16.24 16.24l2.83 2.83"/><path d="M2 12h4"/><path d="M18 12h4"/></svg>
          </div>
          <h3>AI strategy</h3>
          <p>I'll find the highest-ROI automation opportunities hiding in your operations.</p>
        </div>
        <div class="svc-card">
          <div class="svc-icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#5B8AFF" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/><circle cx="9" cy="10" r="0.5" fill="#5B8AFF"/><circle cx="12" cy="10" r="0.5" fill="#5B8AFF"/><circle cx="15" cy="10" r="0.5" fill="#5B8AFF"/></svg>
          </div>
          <h3>Intelligent chatbots</h3>
          <p>Customer-facing agents that understand your business — not canned responses.</p>
        </div>
        <div class="svc-card">
          <div class="svc-icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#5B8AFF" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>
          </div>
          <h3>Team training</h3>
          <p>Hands-on workshops so your people are confident with AI, not intimidated by it.</p>
        </div>
        <div class="svc-card">
          <div class="svc-icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#5B8AFF" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><circle cx="12" cy="12" r="5"/><circle cx="12" cy="12" r="1" fill="#5B8AFF"/><path d="M12 3v2"/><path d="M12 19v2"/><path d="M3 12h2"/><path d="M19 12h2"/></svg>
          </div>
          <h3>Systems audit</h3>
          <p>I'll map your entire stack and show you exactly what AI can take off your plate.</p>
        </div>
      </div>
    </div>
  </section>

  <div class="divider"></div>

  <!-- PROOF -->
  <section class="section">
    <div class="container">
      <p class="section-label">Track record</p>
      <h2 class="section-title">I use what I sell</h2>
      <p class="section-sub">Hermes — my personal AI — runs on the same stack I build for clients.</p>
      <div class="stats-grid">
        <div class="stat-card">
          <span class="stat-num">10+</span>
          <span class="stat-label">Years in agencies</span>
        </div>
        <div class="stat-card">
          <span class="stat-num">100s</span>
          <span class="stat-label">Projects shipped</span>
        </div>
        <div class="stat-card">
          <span class="stat-num">24/7</span>
          <span class="stat-label">Hermes in production</span>
        </div>
      </div>
      <div class="demo-box">
        <div class="demo-grid-bg"></div>
        <div class="demo-inner">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="rgba(91,138,255,0.3)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="5" y="2" width="14" height="20" rx="2"/><path d="M12 18h.01"/></svg>
          <p>Hermes app demo / screenshot</p>
        </div>
      </div>
    </div>
  </section>

  <div class="divider"></div>

  <!-- PROCESS -->
  <section class="section">
    <div class="container">
      <p class="section-label">Process</p>
      <h2 class="section-title">Three steps. No mystery.</h2>
      <p class="section-sub">Agency-tested process, adapted for AI.</p>
      <div class="steps">
        <div class="step">
          <div class="step-num">01</div>
          <div class="step-content">
            <h3>Discovery</h3>
            <p>We talk about what's eating your team's time. No pitch, no pressure — just questions and listening.</p>
          </div>
        </div>
        <div class="step">
          <div class="step-num">02</div>
          <div class="step-content">
            <h3>Audit and scope</h3>
            <p>I map your workflow, identify the highest-impact automations, and give you a clear plan with real costs.</p>
          </div>
        </div>
        <div class="step">
          <div class="step-num">03</div>
          <div class="step-content">
            <h3>Build and deliver</h3>
            <p>I build it, test it, train your team, and stick around until it's running smoothly.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <div class="divider"></div>

  <!-- ABOUT -->
  <section id="about" class="section">
    <div class="container">
      <p class="section-label">About</p>
      <div class="about-block">
        <div class="about-avatar">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#5B8AFF" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
        </div>
        <div class="about-text">
          <h2 class="about-name">{content.about_name}</h2>
          <p class="about-title">{content.about_title}</p>
          {content.about_bio.split('\n\n').map((p: string) => <p>{p}</p>)}
        </div>
      </div>
    </div>
  </section>

  <div class="divider"></div>

  <!-- CONTACT -->
  <section id="contact" class="section contact-section">
    <div class="contact-glow"></div>
    <div class="container" style="text-align:center;">
      <p class="section-label">Contact</p>
      <h2 class="section-title">{content.contact_heading}</h2>
      <p class="section-sub">{content.contact_sub}</p>
      <form class="contact-form" action="https://formspree.io/f/xnjkzged" method="POST">
        <div class="form-row">
          <input type="text" name="name" placeholder="Your name" required />
          <input type="text" name="company" placeholder="Company" />
        </div>
        <input type="email" name="email" placeholder="name@company.com" required />
        <textarea name="message" placeholder="What's eating your team's time?" rows="4" required></textarea>
        <button type="submit" class="btn-primary" style="width:100%;justify-content:center;">Send message <span aria-hidden="true">→</span></button>
      </form>
    </div>
  </section>

  <!-- FOOTER -->
  <footer class="footer">
    <div class="container footer-inner">
      <div class="footer-logo">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
          <circle cx="12" cy="8" r="3" stroke="rgba(91,138,255,0.3)" stroke-width="1.5" fill="none"/>
          <path d="M12 11v6" stroke="rgba(91,138,255,0.3)" stroke-width="1.5" stroke-linecap="round"/>
          <path d="M9 20l3-3 3 3" stroke="rgba(91,138,255,0.3)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        <span>Brightthink AI</span>
      </div>
      <span>brightthinkai.com</span>
    </div>
  </footer>
</Layout>

<style>
  /* NAV */
  .nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    background: rgba(12,16,32,0.85);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border-bottom: 1px solid rgba(99,130,255,0.12);
  }
  .nav-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    height: 64px;
  }
  .nav-logo {
    display: flex;
    align-items: center;
    gap: 10px;
    font-weight: 500;
    font-size: 16px;
    color: #E8ECFF;
    letter-spacing: -0.3px;
  }
  .nav-links {
    display: flex;
    gap: 32px;
    align-items: center;
    font-size: 14px;
    color: rgba(200,210,255,0.6);
  }
  .nav-links a:hover { color: rgba(200,210,255,0.9); }
  .nav-cta {
    background: linear-gradient(135deg, #2E5CFF, #1A3FCC);
    color: #fff !important;
    padding: 8px 20px;
    border-radius: 20px;
    font-size: 13px;
    font-weight: 500;
    letter-spacing: 0.3px;
  }
  .nav-toggle {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
  }
  .nav-toggle span {
    display: block;
    width: 20px;
    height: 1.5px;
    background: rgba(200,210,255,0.5);
    border-radius: 1px;
  }

  /* HERO */
  .hero {
    padding: 160px 0 100px;
    text-align: center;
    position: relative;
    overflow: hidden;
  }
  .hero-mesh {
    position: absolute;
    inset: -80px -40px -40px;
    background:
      radial-gradient(ellipse 600px 400px at 50% 30%, rgba(30,70,220,0.12) 0%, transparent 70%),
      radial-gradient(ellipse 300px 250px at 75% 70%, rgba(90,50,200,0.06) 0%, transparent 70%),
      radial-gradient(ellipse 200px 200px at 20% 80%, rgba(46,92,255,0.05) 0%, transparent 70%);
    pointer-events: none;
  }
  .hero-grid {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(99,130,255,0.04) 1px, transparent 1px),
      linear-gradient(90deg, rgba(99,130,255,0.04) 1px, transparent 1px);
    background-size: 48px 48px;
    mask-image: radial-gradient(ellipse 500px 400px at 50% 40%, black 0%, transparent 80%);
    -webkit-mask-image: radial-gradient(ellipse 500px 400px at 50% 40%, black 0%, transparent 80%);
    pointer-events: none;
  }
  .hero-scanlines {
    position: absolute;
    inset: 0;
    background: repeating-linear-gradient(0deg, transparent, transparent 3px, rgba(99,130,255,0.006) 3px, rgba(99,130,255,0.006) 4px);
    pointer-events: none;
  }
  .hero-content { position: relative; z-index: 1; }
  .pill {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 11px;
    color: rgba(140,170,255,0.7);
    border: 1px solid rgba(99,130,255,0.12);
    padding: 6px 18px;
    border-radius: 20px;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    margin-bottom: 28px;
    background: rgba(46,92,255,0.04);
  }
  .pill-dot {
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: #4B7BFF;
    animation: pulse-dot 2s ease-in-out infinite;
  }
  @keyframes pulse-dot {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.4; }
  }
  .hero h1 {
    font-size: 48px;
    font-weight: 500;
    color: var(--text-bright);
    line-height: 1.15;
    letter-spacing: -1px;
    margin-bottom: 16px;
  }
  .hero h1 em {
    font-style: normal;
    background: linear-gradient(135deg, #5B8AFF, #8B6FFF);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  .hero-sub {
    font-size: 17px;
    color: var(--text-body);
    max-width: 520px;
    margin: 0 auto 40px;
    line-height: 1.65;
  }
  .hero-ctas {
    display: flex;
    gap: 16px;
    justify-content: center;
    flex-wrap: wrap;
  }

  /* SECTIONS */
  .section { padding: 80px 0; position: relative; }

  /* SERVICES */
  .services-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
  }
  .svc-card {
    background: var(--bg-card);
    border: 1px solid var(--border-subtle);
    border-radius: 14px;
    padding: 28px 24px;
    position: relative;
    overflow: hidden;
    transition: border-color 0.3s ease, transform 0.2s ease;
  }
  .svc-card:hover {
    border-color: rgba(99,130,255,0.25);
    transform: translateY(-2px);
  }
  .svc-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 24px;
    right: 24px;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(46,92,255,0.35), transparent);
  }
  .svc-card::after {
    content: '';
    position: absolute;
    top: 0;
    left: 25%;
    width: 50%;
    height: 50px;
    background: radial-gradient(ellipse, rgba(46,92,255,0.1), transparent);
    pointer-events: none;
  }
  .svc-icon { margin-bottom: 16px; }
  .svc-card h3 {
    font-size: 16px;
    font-weight: 500;
    color: #DCE4FF;
    margin-bottom: 8px;
  }
  .svc-card p {
    font-size: 14px;
    color: rgba(200,215,255,0.65);
    line-height: 1.6;
  }

  /* STATS */
  .stats-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
    margin-bottom: 32px;
  }
  .stat-card {
    text-align: center;
    background: rgba(18,24,48,0.5);
    border-radius: 14px;
    padding: 32px 16px;
    border: 1px solid rgba(99,130,255,0.1);
    position: relative;
    overflow: hidden;
  }
  .stat-card::before {
    content: '';
    position: absolute;
    bottom: 0;
    left: 20%;
    right: 20%;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(46,92,255,0.2), transparent);
  }
  .stat-num {
    display: block;
    font-size: 36px;
    font-weight: 500;
    background: linear-gradient(180deg, #7BA3FF, #3B6BFF);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  .stat-label {
    display: block;
    font-size: 13px;
    color: var(--text-muted);
    margin-top: 8px;
    letter-spacing: 0.3px;
  }

  /* DEMO BOX */
  .demo-box {
    border: 1px solid rgba(99,130,255,0.12);
    border-radius: 16px;
    padding: 48px;
    text-align: center;
    position: relative;
    overflow: hidden;
    background:
      radial-gradient(ellipse 400px 200px at 50% 100%, rgba(46,92,255,0.06), transparent),
      rgba(16,20,38,0.6);
  }
  .demo-grid-bg {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(99,130,255,0.02) 1px, transparent 1px),
      linear-gradient(90deg, rgba(99,130,255,0.02) 1px, transparent 1px);
    background-size: 20px 20px;
    pointer-events: none;
  }
  .demo-inner {
    position: relative;
    z-index: 1;
  }
  .demo-inner p {
    font-size: 14px;
    color: var(--text-muted);
    margin-top: 12px;
  }

  /* STEPS */
  .steps { max-width: 560px; }
  .step {
    display: flex;
    align-items: flex-start;
    gap: 24px;
    padding: 24px 0;
    position: relative;
  }
  .step:not(:last-child)::after {
    content: '';
    position: absolute;
    left: 19px;
    top: 68px;
    bottom: 0;
    width: 1px;
    background: linear-gradient(180deg, rgba(99,130,255,0.2), rgba(99,130,255,0.05));
  }
  .step-num {
    min-width: 40px;
    height: 40px;
    border-radius: 12px;
    background: rgba(46,92,255,0.12);
    border: 1px solid rgba(46,92,255,0.2);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 14px;
    font-weight: 500;
    color: #5B8AFF;
    position: relative;
    flex-shrink: 0;
  }
  .step-num::after {
    content: '';
    position: absolute;
    inset: -4px;
    border-radius: 16px;
    background: radial-gradient(circle, rgba(46,92,255,0.08), transparent);
    pointer-events: none;
  }
  .step h3 {
    font-size: 16px;
    font-weight: 500;
    color: #DCE4FF;
    margin-bottom: 6px;
  }
  .step p {
    font-size: 14px;
    color: var(--text-body);
    line-height: 1.65;
  }

  /* ABOUT */
  .about-block {
    display: flex;
    gap: 28px;
    align-items: flex-start;
  }
  .about-avatar {
    min-width: 80px;
    height: 80px;
    border-radius: 18px;
    background: linear-gradient(135deg, rgba(46,92,255,0.15), rgba(100,60,255,0.1));
    border: 1px solid rgba(99,130,255,0.1);
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    flex-shrink: 0;
  }
  .about-avatar::after {
    content: '';
    position: absolute;
    inset: -5px;
    border-radius: 23px;
    background: radial-gradient(circle, rgba(46,92,255,0.06), transparent);
    pointer-events: none;
  }
  .about-name {
    font-size: 22px;
    font-weight: 500;
    color: var(--text-heading);
    margin-bottom: 4px;
  }
  .about-title {
    font-size: 14px;
    color: #5B8AFF;
    margin-bottom: 18px;
  }
  .about-text p {
    font-size: 15px;
    color: var(--text-body);
    line-height: 1.7;
    margin-bottom: 14px;
  }
  .about-text p:last-child { margin-bottom: 0; }

  /* CONTACT */
  .contact-section { overflow: hidden; }
  .contact-glow {
    position: absolute;
    top: -80px;
    left: 50%;
    transform: translateX(-50%);
    width: 500px;
    height: 300px;
    background: radial-gradient(ellipse, rgba(46,92,255,0.06), transparent);
    pointer-events: none;
  }
  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 14px;
    max-width: 500px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
    text-align: left;
  }
  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 14px;
  }
  .contact-form input,
  .contact-form textarea {
    background: rgba(16,22,42,0.7);
    border: 1px solid rgba(99,130,255,0.15);
    border-radius: 10px;
    padding: 14px 18px;
    font-size: 14px;
    color: var(--text-bright);
    font-family: var(--font-sans);
    outline: none;
    width: 100%;
    transition: border-color 0.2s ease;
  }
  .contact-form input::placeholder,
  .contact-form textarea::placeholder {
    color: var(--text-muted);
  }
  .contact-form input:focus,
  .contact-form textarea:focus {
    border-color: rgba(99,130,255,0.35);
  }
  .contact-form textarea { resize: none; }

  /* FOOTER */
  .footer {
    border-top: 1px solid rgba(99,130,255,0.1);
    padding: 24px 0;
  }
  .footer-inner {
    display: flex;
