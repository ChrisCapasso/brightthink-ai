---
import Layout from '../layouts/Layout.astro';
import content from '../content/homepage.json';
---

<Layout>
  <!-- NAV -->
  <nav class="nav">
    <div class="container nav-inner">
      <a href="/" class="logo" aria-label="Brightthink AI — home">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 180 40" width="180" height="40" aria-hidden="true">
          <!-- Hub -->
          <circle cx="20" cy="20" r="5" fill="#4B8EF1"/>
          <!-- Arms -->
          <line x1="20" y1="15" x2="20" y2="4.5"  stroke="#4B8EF1" stroke-width="1.25" stroke-linecap="round"/>
          <line x1="25" y1="20" x2="35.5" y2="20" stroke="#4B8EF1" stroke-width="1.25" stroke-linecap="round"/>
          <line x1="20" y1="25" x2="20" y2="35.5" stroke="#4B8EF1" stroke-width="1.25" stroke-linecap="round"/>
          <line x1="15" y1="20" x2="4.5"  y2="20" stroke="#4B8EF1" stroke-width="1.25" stroke-linecap="round"/>
          <!-- Dots -->
          <circle cx="20"   cy="4.5"  r="2.2" fill="#4B8EF1"/>
          <circle cx="35.5" cy="20"   r="2.2" fill="#4B8EF1"/>
          <circle cx="20"   cy="35.5" r="2.2" fill="#4B8EF1"/>
          <circle cx="4.5"  cy="20"   r="2.2" fill="#4B8EF1"/>
          <!-- Wordmark -->
          <text x="48" y="26" font-family="-apple-system,BlinkMacSystemFont,'Inter','Segoe UI',sans-serif" font-size="18" fill="#111827" letter-spacing="-0.4">
            <tspan font-weight="300">bright</tspan><tspan font-weight="600">think</tspan>
          </text>
          <!-- AI accent -->
          <text x="156" y="17" font-family="-apple-system,BlinkMacSystemFont,'Inter','Segoe UI',sans-serif" font-size="8" font-weight="500" fill="#4B8EF1" letter-spacing="1.5">AI</text>
        </svg>
      </a>
      <div class="nav-links">
        <a href="#services">Services</a>
        <a href="#about">About</a>
        <a href="#contact" class="nav-cta">Get in touch</a>
      </div>
      <button class="nav-toggle" aria-label="Menu">
        <span></span><span></span>
      </button>
    </div>
  </nav>

  <!-- HERO -->
  <section class="hero">
    <div class="hero-mesh"></div>
    <div class="hero-grid"></div>
    <div class="hero-scanlines"></div>
    <div class="container hero-content">
      <span class="pill"><span class="pill-dot"></span> {content.hero_pill}</span>
      <h1>{content.hero_tagline}<br><em>{content.hero_tagline_em}</em></h1>
      <p class="hero-sub">{content.hero_sub}</p>
      <div class="hero-ctas">
        <a href="#contact" class="btn-primary">Let's talk <span aria-hidden="true">→</span></a>
        <a href="#services" class="btn-ghost">See what I build</a>
      </div>
    </div>
  </section>

  <div class="divider"></div>

  <!-- SERVICES -->
  <section id="services" class="section">
    <div class="container">
      <p class="section-label">Services</p>
      <h2 class="section-title">What I build</h2>
      <p class="section-sub">Practical AI that fits how you already work.</p>
      <div class="services-grid">
        <div class="svc-card">
          <div class="svc-icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#4B8EF1" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="12" rx="2"/><path d="M9 20h6"/><path d="M12 16v4"/><circle cx="9" cy="10" r="1" fill="#4B8EF1"/><circle cx="15" cy="10" r="1" fill="#4B8EF1"/></svg>
          </div>
          <h3>Custom AI agents</h3>
          <p>Autonomous agents that handle the tasks your team does manually every single day.</p>
        </div>
        <div class="svc-card">
          <div class="svc-icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#4B8EF1" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 8h16"/><path d="M4 16h16"/><path d="M8 4v4"/><path d="M16 16v4"/><path d="M8 12l4-4 4 4"/><path d="M8 12l4 4 4-4"/></svg>
          </div>
          <h3>Workflow automation</h3>
          <p>Connect your tools. Eliminate the busywork. Let your team focus on what actually matters.</p>
        </div>
        <div class="svc-card">
          <div class="svc-icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#4B8EF1" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M12 2v4"/><path d="M12 18v4"/><path d="M4.93 4.93l2.83 2.83"/><path d="M16.24 16.24l2.83 2.83"/><path d="M2 12h4"/><path d="M18 12h4"/></svg>
          </div>
          <h3>AI strategy</h3>
          <p>I'll find the highest-ROI automation opportunities hiding in your operations.</p>
        </div>
        <div class="svc-card">
          <div class="svc-icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#4B8EF1" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/><circle cx="9" cy="10" r="0.5" fill="#4B8EF1"/><circle cx="12" cy="10" r="0.5" fill="#4B8EF1"/><circle cx="15" cy="10" r="0.5" fill="#4B8EF1"/></svg>
          </div>
          <h3>Intelligent chatbots</h3>
          <p>Customer-facing agents that understand your business — not canned responses.</p>
        </div>
        <div class="svc-card">
          <div class="svc-icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#4B8EF1" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>
          </div>
          <h3>Team training</h3>
          <p>Hands-on workshops so your people are confident with AI, not intimidated by it.</p>
        </div>
        <div class="svc-card">
          <div class="svc-icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#4B8EF1" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><circle cx="12" cy="12" r="5"/><circle cx="12" cy="12" r="1" fill="#4B8EF1"/><path d="M12 3v2"/><path d="M12 19v2"/><path d="M3 12h2"/><path d="M19 12h2"/></svg>
          </div>
          <h3>Systems audit</h3>
          <p>I'll map your entire stack and show you exactly what AI can take off your plate.</p>
        </div>
      </div>
    </div>
  </section>

  <div class="divider"></div>

  <!-- PROOF -->
  <section class="section">
    <div class="container">
      <p class="section-label">Track record</p>
      <h2 class="section-title">I use what I sell</h2>
      <p class="section-sub">Hermes — my personal AI — runs on the same stack I build for clients.</p>
      <div class="stats-grid">
        <div class="stat-card">
          <span class="stat-num">10+</span>
          <span class="stat-label">Years in agencies</span>
        </div>
        <div class="stat-card">
          <span class="stat-num">100s</span>
          <span class="stat-label">Projects shipped</span>
        </div>
        <div class="stat-card">
          <span class="stat-num">24/7</span>
          <span class="stat-label">Hermes in production</span>
        </div>
      </div>
      <div class="demo-box">
        <div class="demo-grid-bg"></div>
        <div class="demo-inner">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="rgba(91,138,255,0.3)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="5" y="2" width="14" height="20" rx="2"/><path d="M12 18h.01"/></svg>
          <p>Hermes app demo / screenshot</p>
        </div>
      </div>
    </div>
  </section>

  <div class="divider"></div>

  <!-- PROCESS -->
  <section class="section">
    <div class="container">
      <p class="section-label">Process</p>
      <h2 class="section-title">Three steps. No mystery.</h2>
      <p class="section-sub">Agency-tested process, adapted for AI.</p>
      <div class="steps">
        <div class="step">
          <div class="step-num">01</div>
          <div class="step-content">
            <h3>Discovery</h3>
            <p>We talk about what's eating your team's time. No pitch, no pressure — just questions and listening.</p>
          </div>
        </div>
        <div class="step">
          <div class="step-num">02</div>
          <div class="step-content">
            <h3>Audit and scope</h3>
            <p>I map your workflow, identify the highest-impact automations, and give you a clear plan with real costs.</p>
          </div>
        </div>
        <div class="step">
          <div class="step-num">03</div>
          <div class="step-content">
            <h3>Build and deliver</h3>
            <p>I build it, test it, train your team, and stick around until it's running smoothly.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <div class="divider"></div>

  <!-- ABOUT -->
  <section id="about" class="section">
    <div class="container">
      <p class="section-label">About</p>
      <div class="about-block">
        <div class="about-avatar">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#4B8EF1" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
        </div>
        <div class="about-text">
          <h2 class="about-name">{content.about_name}</h2>
          <p class="about-title">{content.about_title}</p>
          {content.about_bio.split('\n\n').map((p: string) => <p>{p}</p>)}
        </div>
      </div>
    </div>
  </section>

  <div class="divider"></div>

  <!-- CONTACT -->
  <section id="contact" class="section contact-section">
    <div class="contact-glow"></div>
    <div class="container" style="text-align:center;">
      <p class="section-label">Contact</p>
      <h2 class="section-title">{content.contact_heading}</h2>
      <p class="section-sub">{content.contact_sub}</p>
      <form class="contact-form" action="https://formspree.io/f/xnjkzged" method="POST">
        <div class="form-row">
          <input type="text" name="name" placeholder="Your name" required />
          <input type="text" name="company" placeholder="Company" />
        </div>
        <input type="email" name="email" placeholder="name@company.com" required />
        <textarea name="message" placeholder="What's eating your team's time?" rows="4" required></textarea>
        <button type="submit" class="btn-primary" style="width:100%;justify-content:center;">Send message <span aria-hidden="true">→</span></button>
      </form>
    </div>
  </section>

  <!-- FOOTER -->
  <footer class="footer">
    <div class="container footer-inner">
      <div class="footer-logo">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 40 40" width="20" height="20" aria-hidden="true">
          <circle cx="20" cy="20" r="5" fill="#4B8EF1"/>
          <line x1="20" y1="15" x2="20" y2="4.5"  stroke="#4B8EF1" stroke-width="1.25" stroke-linecap="round"/>
          <line x1="25" y1="20" x2="35.5" y2="20" stroke="#4B8EF1" stroke-width="1.25" stroke-linecap="round"/>
          <line x1="20" y1="25" x2="20" y2="35.5" stroke="#4B8EF1" stroke-width="1.25" stroke-linecap="round"/>
          <line x1="15" y1="20" x2="4.5"  y2="20" stroke="#4B8EF1" stroke-width="1.25" stroke-linecap="round"/>
          <circle cx="20"   cy="4.5"  r="2.2" fill="#4B8EF1"/>
          <circle cx="35.5" cy="20"   r="2.2" fill="#4B8EF1"/>
          <circle cx="20"   cy="35.5" r="2.2" fill="#4B8EF1"/>
          <circle cx="4.5"  cy="20"   r="2.2" fill="#4B8EF1"/>
        </svg>
        <span>Brightthink AI</span>
      </div>
      <span>brightthinkai.com</span>
    </div>
  </footer>
</Layout>

<style>
  /* NAV */
  .nav {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 100;
    background: rgba(255,255,255,0.92);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border-bottom: 0.5px solid var(--border);
  }
  .nav-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    height: 60px;
  }
  .logo {
    display: flex;
    align-items: center;
    text-decoration: none;
  }
  .nav-links {
    display: flex;
    gap: 28px;
    align-items: center;
    font-size: 14px;
    color: var(--text-secondary);
  }
  .nav-links a:hover { color: var(--text-primary); }
  .nav-cta {
    background: var(--blue);
    color: #fff !important;
    padding: 7px 18px;
    border-radius: 8px;
    font-size: 13px;
    font-weight: 500;
    transition: background 0.15s ease;
  }
  .nav-cta:hover { background: var(--blue-hover) !important; }
  .nav-toggle {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
  }
  .nav-toggle span {
    display: block;
    width: 20px;
    height: 1.5px;
    background: var(--text-secondary);
    border-radius: 1px;
  }

  /* HERO */
  .hero {
    padding: 148px 0 96px;
    text-align: center;
    position: relative;
    overflow: hidden;
    background: var(--bg-page);
  }
  .hero-mesh {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 700px 400px at 50% 0%, rgba(75,142,241,0.07) 0%, transparent 70%);
    pointer-events: none;
  }
  .hero-grid {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(75,142,241,0.05) 1px, transparent 1px),
      linear-gradient(90deg, rgba(75,142,241,0.05) 1px, transparent 1px);
    background-size: 48px 48px;
    mask-image: radial-gradient(ellipse 600px 350px at 50% 30%, black 0%, transparent 80%);
    -webkit-mask-image: radial-gradient(ellipse 600px 350px at 50% 30%, black 0%, transparent 80%);
    pointer-events: none;
  }
  .hero-scanlines { display: none; }
  .hero-content { position: relative; z-index: 1; }

  .pill {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 11px;
    color: var(--blue);
    border: 0.5px solid var(--border-accent);
    padding: 5px 16px;
    border-radius: 20px;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    margin-bottom: 28px;
    background: var(--bg-accent);
    font-weight: 500;
  }
  .pill-dot {
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--blue);
    animation: pulse-dot 2s ease-in-out infinite;
  }
  @keyframes pulse-dot {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.35; }
  }
  .hero h1 {
    font-size: 48px;
    font-weight: 500;
    color: var(--text-primary);
    line-height: 1.15;
    letter-spacing: -1px;
    margin-bottom: 18px;
  }
  .hero h1 em {
    font-style: normal;
    color: var(--blue);
  }
  .hero-sub {
    font-size: 17px;
    color: var(--text-secondary);
    max-width: 520px;
    margin: 0 auto 40px;
    line-height: 1.65;
  }
  .hero-ctas {
    display: flex;
    gap: 12px;
    justify-content: center;
    flex-wrap: wrap;
  }

  /* SECTIONS */
  .section { padding: 80px 0; position: relative; }

  /* SERVICES */
  .services-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 12px;
  }
  .svc-card {
    background: var(--bg-card);
    border: 0.5px solid var(--border);
    border-radius: 12px;
    padding: 24px 20px;
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
  }
  .svc-card:hover {
    border-color: var(--border-accent);
    box-shadow: 0 4px 16px rgba(75,142,241,0.08);
  }
  .svc-icon { margin-bottom: 14px; }
  .svc-card h3 {
    font-size: 15px;
    font-weight: 500;
    color: var(--text-primary);
    margin-bottom: 6px;
  }
  .svc-card p {
    font-size: 13px;
    color: var(--text-secondary);
    line-height: 1.65;
  }

  /* STATS */
  .stats-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 12px;
    margin-bottom: 32px;
  }
  .stat-card {
    text-align: center;
    background: var(--bg-card);
    border-radius: 12px;
    padding: 32px 16px;
    border: 0.5px solid var(--border);
  }
  .stat-num {
    display: block;
    font-size: 36px;
    font-weight: 500;
    color: var(--blue);
    line-height: 1.1;
  }
  .stat-label {
    display: block;
    font-size: 13px;
    color: var(--text-muted);
    margin-top: 8px;
  }

  /* DEMO BOX */
  .demo-box {
    border: 0.5px solid var(--border);
    border-radius: 12px;
    padding: 48px;
    text-align: center;
    background: var(--bg-surface);
    position: relative;
    overflow: hidden;
  }
  .demo-grid-bg {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(75,142,241,0.04) 1px, transparent 1px),
      linear-gradient(90deg, rgba(75,142,241,0.04) 1px, transparent 1px);
    background-size: 20px 20px;
    pointer-events: none;
  }
  .demo-inner { position: relative; z-index: 1; }
  .demo-inner p {
    font-size: 14px;
    color: var(--text-muted);
    margin-top: 12px;
  }

  /* STEPS */
  .steps { max-width: 560px; }
  .step {
    display: flex;
    align-items: flex-start;
    gap: 20px;
    padding: 24px 0;
    position: relative;
  }
  .step:not(:last-child)::after {
    content: '';
    position: absolute;
    left: 19px;
    top: 68px;
    bottom: 0;
    width: 1px;
    background: linear-gradient(180deg, var(--border-medium), transparent);
  }
  .step-num {
    min-width: 40px;
    height: 40px;
    border-radius: 10px;
    background: var(--bg-accent);
    border: 0.5px solid var(--border-accent);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 13px;
    font-weight: 500;
    color: var(--blue);
    flex-shrink: 0;
  }
  .step h3 {
    font-size: 15px;
    font-weight: 500;
    color: var(--text-primary);
    margin-bottom: 4px;
  }
  .step p {
    font-size: 14px;
    color: var(--text-secondary);
    line-height: 1.65;
  }

  /* ABOUT */
  .about-block {
    display: flex;
    gap: 28px;
    align-items: flex-start;
  }
  .about-avatar {
    min-width: 80px;
    height: 80px;
    border-radius: 16px;
    background: var(--bg-accent);
    border: 0.5px solid var(--border-accent);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .about-name {
    font-size: 22px;
    font-weight: 500;
    color: var(--text-primary);
    margin-bottom: 4px;
  }
  .about-title {
    font-size: 14px;
    color: var(--blue);
    margin-bottom: 16px;
    font-weight: 500;
  }
  .about-text p {
    font-size: 15px;
    color: var(--text-secondary);
    line-height: 1.7;
    margin-bottom: 14px;
  }
  .about-text p:last-child { margin-bottom: 0; }

  /* CONTACT */
  .contact-section { overflow: hidden; }
  .contact-glow { display: none; }
  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 12px;
    max-width: 500px;
    margin: 0 auto;
    text-align: left;
  }
  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
  }
  .contact-form input,
  .contact-form textarea {
    background: var(--bg-card);
    border: 0.5px solid var(--border-medium);
    border-radius: 8px;
    padding: 12px 16px;
    font-size: 14px;
    color: var(--text-primary);
    font-family: var(--font-sans);
    outline: none;
    width: 100%;
    transition: border-color 0.2s ease;
  }
  .contact-form input::placeholder,
  .contact-form textarea::placeholder {
    color: var(--text-muted);
  }
  .contact-form input:focus,
  .contact-form textarea:focus {
    border-color: var(--blue);
    box-shadow: 0 0 0 3px rgba(75,142,241,0.08);
  }
  .contact-form textarea { resize: none; }

  /* FOOTER */
  .footer {
    border-top: 0.5px solid var(--border);
    padding: 24px 0;
    background: var(--bg-page);
  }
  .footer-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 12px;
    color: var(--text-muted);
  }
  .footer-logo {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  /* MOBILE */
  @media (max-width: 768px) {
    .nav-links { display: none; }
    .nav-toggle { display: flex; }
    .hero { padding: 112px 0 60px; }
    .hero h1 { font-size: 32px; }
    .hero-sub { font-size: 15px; }
    .services-grid { grid-template-columns: 1fr; }
    .stats-grid { grid-template-columns: 1fr; }
    .form-row { grid-template-columns: 1fr; }
    .about-block { flex-direction: column; }
    .section { padding: 60px 0; }
  }
  @media (min-width: 769px) and (max-width: 1024px) {
    .services-grid { grid-template-columns: repeat(2, 1fr); }
  }
</style>
